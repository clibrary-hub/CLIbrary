{
  "name": "note-graph",
  "version": "0.1.0",
  "description": "筆記圖譜器",
  "category": "R",
  "number": 344,
  "pain_point": "筆記轉知識圖",
  "commercial": "✅",
  "language": "Python",
  "dependencies": [
    "networkx",
    "click",
    "rich"
  ],
  "agent_compatible": true,
  "mcp_ready": true,
  "intent_triggers": [
    "把我的筆記視覺化成知識圖譜",
    "分析筆記連結關係並生成圖表",
    "找出筆記中最核心的節點",
    "我想看筆記之間的關聯網絡",
    "哪幾篇筆記是知識圖中的樞紐",
    "把 Obsidian vault 轉成知識圖",
    "分析哪些主題有最多相互連結"
  ],
  "examples": [
    {
      "query": "分析 ~/vault 生成筆記知識圖並輸出 graph.json",
      "params": {
        "notes_dir": "~/vault",
        "output_file": "graph.json"
      }
    },
    {
      "query": "找出 notes/ 中連結最多的前 10 個核心筆記",
      "params": {
        "notes_dir": "notes/",
        "top_hubs": 10
      }
    },
    {
      "query": "生成以 machine-learning.md 為中心的局部知識圖（2 層）",
      "params": {
        "notes_dir": "notes/",
        "center_note": "machine-learning.md",
        "depth": 2
      }
    }
  ],
  "params_schema": {
    "type": "object",
    "properties": {
      "center_note": {
        "type": "string"
      },
      "depth": {
        "type": "integer"
      },
      "notes_dir": {
        "type": "string"
      },
      "output_file": {
        "type": "string"
      },
      "top_hubs": {
        "type": "integer"
      }
    },
    "required": [
      "notes_dir"
    ]
  },
  "license": "MIT"
}
