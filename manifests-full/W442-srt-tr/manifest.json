{
  "name": "srt-tr",
  "version": "0.1.0",
  "description": "SRT 翻譯器",
  "category": "W",
  "number": 442,
  "pain_point": "字幕翻譯",
  "commercial": "⚠️",
  "language": "Python",
  "dependencies": [
    "anthropic",
    "click",
    "rich"
  ],
  "agent_compatible": true,
  "mcp_ready": true,
  "intent_triggers": [
    "幫我把英文字幕翻成中文",
    "翻譯這個 SRT 字幕檔",
    "我要把 Netflix 影片的字幕翻成繁體中文",
    "字幕檔翻譯，保留時間軸格式",
    "把日文字幕翻成英文",
    "處理 VTT 或 SRT 格式的字幕翻譯",
    "批次翻譯多個字幕檔案"
  ],
  "examples": [
    {
      "query": "翻譯 movie.srt 英文字幕到繁體中文",
      "params": {
        "input_file": "movie.srt",
        "source_lang": "en",
        "target_lang": "zh-TW"
      }
    },
    {
      "query": "把 anime_ep01.srt 日文字幕翻成中文，保留原始時間軸",
      "params": {
        "input_file": "anime_ep01.srt",
        "source_lang": "ja",
        "target_lang": "zh-TW",
        "preserve_timing": true
      }
    },
    {
      "query": "批次翻譯 /subtitles 下所有 SRT 檔案到中文",
      "params": {
        "input_dir": "/subtitles",
        "target_lang": "zh-TW",
        "output_suffix": "_zh"
      }
    }
  ],
  "params_schema": {
    "type": "object",
    "properties": {
      "input_dir": {
        "type": "string"
      },
      "input_file": {
        "type": "string"
      },
      "output_suffix": {
        "type": "string"
      },
      "preserve_timing": {
        "type": "boolean"
      },
      "source_lang": {
        "type": "string"
      },
      "target_lang": {
        "type": "string"
      }
    },
    "required": [
      "target_lang"
    ]
  },
  "license": "MIT"
}
