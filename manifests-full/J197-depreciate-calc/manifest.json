{
  "name": "depreciate-calc",
  "version": "0.1.0",
  "description": "折舊計算器",
  "category": "J",
  "number": 197,
  "pain_point": "折舊攤提難算",
  "commercial": "✅",
  "language": "Python",
  "dependencies": [
    "click",
    "rich",
    "decimal"
  ],
  "agent_compatible": true,
  "mcp_ready": true,
  "intent_triggers": [
    "幫我計算電腦設備的年度折舊金額",
    "固定資產折舊攤提，用直線法計算",
    "公司買了機器設備，幫我算每年折舊費用",
    "折舊計算器，支援直線法和加速折舊",
    "想知道資產帳面價值每年減少多少",
    "計算 5 年使用年限的設備折舊時間表",
    "稅務折舊和會計折舊的試算工具"
  ],
  "examples": [
    {
      "query": "計算價值 NT$120,000 的筆電，使用年限 5 年，殘值 NT$10,000 的直線折舊",
      "params": {
        "action": "calculate",
        "cost": "120000",
        "salvage": "10000",
        "life_years": "5",
        "method": "straight_line"
      }
    },
    {
      "query": "用餘額遞減法計算 NT$200,000 機器設備 10 年折舊明細",
      "params": {
        "action": "calculate",
        "cost": "200000",
        "life_years": "10",
        "method": "declining_balance",
        "output": "depreciation-schedule.csv"
      }
    },
    {
      "query": "比較直線法和加速折舊法對同一設備的年度費用差異",
      "params": {
        "action": "compare",
        "cost": "500000",
        "life_years": "7"
      }
    }
  ],
  "params_schema": {
    "type": "object",
    "properties": {
      "action": {
        "type": "string"
      },
      "cost": {
        "type": "string"
      },
      "life_years": {
        "type": "string"
      },
      "method": {
        "type": "string"
      },
      "output": {
        "type": "string"
      },
      "salvage": {
        "type": "string"
      }
    },
    "required": [
      "action",
      "cost",
      "life_years"
    ]
  },
  "license": "MIT"
}
